<!DOCTYPE html>
<html lang="hu">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Trustic{% endblock %}</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-dark bg-dark mb-4">
            <div class="container" style="max-width: 70%;">
                <a class="navbar-brand fw-bold" href="{{ path('review_index') }}">Trustic</a>
                <div class="d-flex gap-3">
                    <a href="{{ path('review_index') }}" class="nav-link text-white">Értékelések</a>
                    <a href="{{ path('company_index') }}" class="nav-link text-white">Cégek</a>
                    <a href="{{ path('review_add') }}" class="nav-link text-white">Új értékelés</a>
                </div>
            </div>
        </nav>

        <div class="container" style="max-width: 70%;">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
