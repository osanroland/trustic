{% extends 'base.html.twig' %}

{% block title %}Cégek — Trustic{% endblock %}

{% block body %}
    <h1 class="h3 mb-4">Cégek</h1>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Cégnév</th>
                <th>Vélemények száma</th>
                <th>Átlagos értékelés</th>
            </tr>
        </thead>
        <tbody>
            {% for company in companies %}
                <tr>
                    <td>{{ company.companyName }}</td>
                    <td>{{ company.count }}</td>
                    <td>
                        {% set avg = company.avgRating|round(1) %}
                        {% for i in 1..5 %}
                            <i class="bi bi-star{{ i <= avg ? '-fill' : (i - 0.5 <= avg ? '-half' : '') }}" style="color: {{ i - 0.5 <= avg ? '#ffc107' : '#ccc' }};"></i>
                        {% endfor %}
                        <small class="text-muted ms-1">{{ avg }}/5</small>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center text-muted">Nincs adat.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
