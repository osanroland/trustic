{% extends 'base.html.twig' %}

{% block title %}Értékelések — Trustic{% endblock %}

{% block body %}
    <div class="d-flex align-items-center justify-content-between mb-4 gap-3">
        <h1 class="h3 mb-0 flex-shrink-0">Értékelések</h1>

        <form method="get" action="{{ path('review_index') }}" class="d-flex gap-2 flex-grow-1 justify-content-center" style="max-width: 400px; margin: 0 auto;">
            <input type="text"
                   name="search"
                   value="{{ search }}"
                   placeholder="Keresés cégnév alapján…"
                   class="form-control form-control-sm">
            <button type="submit" class="btn btn-sm flex-shrink-0" style="color: #00a651; border-color: #00a651;">Keresés</button>
            {% if search %}
                <a href="{{ path('review_index') }}" class="btn btn-outline-danger btn-sm flex-shrink-0">×</a>
            {% endif %}
        </form>

        <a href="{{ path('review_add') }}" class="btn btn-primary flex-shrink-0">Új értékelés</a>
    </div>

    <table class="table table-hover">
        <thead style="--bs-table-bg: #00a651; --bs-table-color: #fff; color: #fff;">
            <tr>
                <th>Cég</th>
                <th>Értékelés</th>
                <th>Vélemény</th>
                <th>Dátum</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for review in reviews %}
                <tr>
                    <td>{{ review.companyName }}</td>
                    <td>
                        {% for i in 1..5 %}
                            <i class="bi bi-star{{ i <= review.rating ? '-fill' : '' }} small" style="color: {{ i <= review.rating ? '#ffc107' : '#ccc' }};"></i>
                        {% endfor %}
                    </td>
                    <td>{{ review.reviewText|length > 100 ? review.reviewText|slice(0, 100) ~ '…' : review.reviewText }}</td>
                    <td>{{ review.createdAt|date('Y.m.d') }}</td>
                    <td><a href="{{ path('review_details', {id: review.id}) }}" class="btn btn-sm" style="color: #00a651; border-color: #00a651;">Részletek</a></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-muted">Nincs találat.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if totalPages > 1 %}
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('review_index', {page: currentPage - 1, search: search}) }}">«</a>
                </li>

                {% for p in 1..totalPages %}
                    <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('review_index', {page: p, search: search}) }}"
                           {% if p == currentPage %}style="background-color: #00a651; border-color: #00a651;"{% endif %}>
                            {{ p }}
                        </a>
                    </li>
                {% endfor %}

                <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('review_index', {page: currentPage + 1, search: search}) }}">»</a>
                </li>
            </ul>
        </nav>
    {% endif %}
{% endblock %}
