{% extends 'base.html.twig' %}

{% block title %}Értékelések — Trustic{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Értékelések</h1>
        <a href="{{ path('review_add') }}" class="btn btn-primary">Új értékelés</a>
    </div>

    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Cég</th>
                <th>Értékelés</th>
                <th>Vélemény</th>
                <th>Dátum</th>
            </tr>
        </thead>
        <tbody>
            {% for review in reviews %}
                <tr>
                    <td>{{ review.companyName }}</td>
                    <td>
                        {% for i in 1..5 %}
                            <i class="bi bi-star{{ i <= review.rating ? '-fill' : '' }} small" style="color: {{ i <= review.rating ? '#ffc107' : '#ccc' }};"></i>
                        {% endfor %}
                    </td>
                    <td>{{ review.reviewText|length > 100 ? review.reviewText|slice(0, 100) ~ '…' : review.reviewText }}</td>
                    <td>{{ review.createdAt|date('Y.m.d') }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">Nincs találat.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
