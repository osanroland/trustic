{% extends 'base.html.twig' %}

{% block title %}Új értékelés — Trustic{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <h1 class="h3 mb-4">Új értékelés</h1>

            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                <div class="mb-3">
                    {{ form_label(form.companyName) }}
                    {{ form_widget(form.companyName, {attr: {class: 'form-control' ~ (form.companyName.vars.errors|length ? ' is-invalid' : '')}}) }}
                    {{ form_errors(form.companyName) }}
                </div>

                <div class="mb-3">
                    <label class="form-label">Értékelés</label>
                    <div class="star-rating d-flex gap-1 align-items-center">
                        {% for i in 1..5 %}
                            <i class="bi bi-star star-icon fs-2"
                               data-value="{{ i }}"
                               role="button"
                               style="cursor: pointer; color: #ccc; transition: color 0.1s;"></i>
                        {% endfor %}
                    </div>
                    {{ form_widget(form.rating) }}
                    {% if form.rating.vars.errors|length %}
                        <div class="invalid-feedback d-block">
                            {% for error in form.rating.vars.errors %}{{ error.message }}{% endfor %}
                        </div>
                    {% endif %}
                </div>

                <div class="mb-3">
                    {{ form_label(form.reviewText) }}
                    {{ form_widget(form.reviewText, {attr: {class: 'form-control' ~ (form.reviewText.vars.errors|length ? ' is-invalid' : '')}}) }}
                    {{ form_errors(form.reviewText) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.authorEmail) }}
                    {{ form_widget(form.authorEmail, {attr: {class: 'form-control' ~ (form.authorEmail.vars.errors|length ? ' is-invalid' : '')}}) }}
                    {{ form_errors(form.authorEmail) }}
                </div>

                <div class="d-flex gap-2">
                    {{ form_widget(form.submit) }}
                    <a href="{{ path('review_index') }}" class="btn btn-outline-secondary">Mégsem</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
    const stars = document.querySelectorAll('.star-icon');
    const ratingInput = document.querySelector('input[name$="[rating]"]');

    function setStars(count, permanent) {
        stars.forEach((star, index) => {
            const filled = index < count;
            star.classList.toggle('bi-star-fill', filled);
            star.classList.toggle('bi-star', !filled);
            star.style.color = filled ? '#ffc107' : '#ccc';
        });
        if (permanent) {
            ratingInput.value = count;
        }
    }

    // Restore selected value on page load (e.g. after failed validation)
    const currentValue = parseInt(ratingInput.value);
    if (currentValue >= 1 && currentValue <= 5) {
        setStars(currentValue, false);
    }

    stars.forEach((star, index) => {
        star.addEventListener('mouseenter', () => setStars(index + 1, false));
        star.addEventListener('click', () => setStars(index + 1, true));
    });

    document.querySelector('.star-rating').addEventListener('mouseleave', () => {
        setStars(parseInt(ratingInput.value) || 0, false);
    });
</script>
{% endblock %}
